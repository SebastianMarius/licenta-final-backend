// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Listing {
  id          String   @id @default(cuid())
  externalId  String   @unique   // OLX: link; Storia: id
  source      String   // "olx" | "storia"
  title       String
  description String?  @db.Text
  url         String?
  price       Decimal? @db.Decimal(12, 2)
  currency    String?  @default("RON")
  city        String?
  address     String?
  areaSqm     Decimal? @db.Decimal(8, 2)
  imageUrls   String[] @default([])
  rawPayload  Json?    // optional: keep original OLX/Storia object
  createdAt   DateTime?
  updatedAt   DateTime?

  @@index([source, city])
}

model ListingScrapeCache {
  id          String   @id @default(cuid())
  searchCity  String
  forma       String   @default("")
  minRoms     Int      @default(0)
  scrapedAt   DateTime @default(now())
  payload     Json

  @@unique([searchCity, forma, minRoms])
}

model User {
  id                       Int       @id @default(autoincrement())
  email                    String    @unique
  passwordHash             String
  passwordResetTokenHash   String?   @unique
  passwordResetExpires     DateTime?
  createdAt                DateTime  @default(now())
  advertisements           Advertisement[]
}

model Advertisement {
  id          String   @id @default(cuid())
  ownerId     Int
  title       String
  description String?  @db.Text
  price       Decimal  @db.Decimal(12, 2)
  currency    String   @default("RON")
  city        String
  citySlug    String
  address     String?
  areaSqm     Decimal? @db.Decimal(8, 2)
  roomsNumber Int?
  imageUrls   String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([citySlug])
}